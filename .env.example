# Required environment variables for ToanTuDuy
# Copy this file to .env.local and fill in the values

# ─── Database ────────────────────────────────────────────────────────────────
# migrations-only (prisma migrate / prisma db seed) — NEVER use at runtime
DATABASE_URL=

# all runtime DB access via Supabase PgBouncer
DATABASE_URL_POOLED=

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ─── Google OAuth (Parent accounts only) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=

# ─── PayOS (Vietnamese payment gateway) ─────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
# WARNING: This key bypasses Supabase Row Level Security entirely.
# Server-side ONLY — never expose in client code or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=
